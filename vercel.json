{
      "buildCommand": "cd dashboard && npm ci && npm run build",
      "outputDirectory": "dashboard/dist",
      "framework": null,
      "rewrites": [
              { "source": "/api/(.*)", "destination": "/api/index" },
              { "source": "/(.*)", "destination": "/index.html" }
      ],
      "functions": {
              "api/index.js": {
                        "memory": 1024,
                        "maxDuration": 10
              }
      }
}
